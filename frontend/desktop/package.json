{
  "name": "greywind-desktop",
  "version": "0.1.0",
  "description": "灰风桌面端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.greywind.desktop",
    "productName": "灰风",
    "win": {
      "target": "nsis",
      "icon": "renderer/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "灰风"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-log.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../../src",
        "to": "backend/src"
      },
      {
        "from": "../../characters",
        "to": "backend/characters"
      },
      {
        "from": "../../pyproject.toml",
        "to": "backend/pyproject.toml"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
