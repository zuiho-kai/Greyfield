{
  "name": "greywind-desktop",
  "version": "0.1.0",
  "description": "灰风桌面端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepare:backend-runtime": "python scripts/prepare_backend_runtime.py",
    "build": "npm run prepare:backend-runtime && electron-builder --win",
    "build:dir": "npm run prepare:backend-runtime && electron-builder --win --dir",
    "build:portable": "npm run prepare:backend-runtime && electron-builder --win portable"
  },
  "build": {
    "appId": "com.greywind.desktop",
    "productName": "灰风",
    "directories": {
      "output": "../.."
    },
    "win": {
      "target": "nsis",
      "icon": "renderer/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "灰风"
    },
    "portable": {
      "artifactName": "GreyWind.exe"
    },
    "files": [
      "main.js",
      "runtime-paths.js",
      "preload.js",
      "preload-history.js",
      "preload-log.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "build/backend-runtime",
        "to": "backend"
      }
    ]
  },
  "dependencies": {
    "koffi": "^2.15.2",
    "screenshot-desktop": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
